{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    /* Relax strict checks for test files */
    "noUncheckedIndexedAccess": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "noImplicitAny": false
  },
  "include": [
    "test/**/*.ts",
    "test/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
